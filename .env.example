# Chave da API-Football v3. Nunca prefixe com NEXT_PUBLIC_.
API_FOOTBALL_KEY=

# Preenchidas automaticamente ao conectar Neon/Postgres no projeto da Vercel.
POSTGRES_URL=
DATABASE_URL=

# Cache persistente de 24 horas: reiniciar o servidor não repete chamadas.
# O Admin também permite atualizar manualmente o feed (até 3 chamadas).
API_FEED_CACHE_SECONDS=86400

# Busca de partidas e consulta de odds sob demanda também ficam em cache por 24h.
API_FOOTBALL_ADMIN_CACHE_SECONDS=86400

# Cada página adicional consome outra chamada e traz até 10 jogos com odds.
API_ODDS_PAGES=1

# Segunda fonte de jogos e odds. A chave real deve existir somente no .env.local.
THE_ODDS_API_KEY=
THE_ODDS_API_CACHE_SECONDS=86400
THE_ODDS_API_REGIONS=eu
THE_ODDS_API_MARKETS=h2h,spreads,totals
THE_ODDS_API_SPORTS=soccer_fifa_world_cup,soccer_conmebol_copa_libertadores,soccer_conmebol_copa_sudamericana,soccer_brazil_serie_b

# Token público usado apenas entre o Web Component e o proxy local.
# Não é a chave da API-Sports e pode ficar visível no navegador.
NEXT_PUBLIC_WIDGET_PROXY_TOKEN=arenaodds-local-widget

# Autenticação local. Troque estes valores antes de usar.
AUTH_SECRET=troque-por-uma-frase-longa-com-mais-de-32-caracteres
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD="ArenaAdmin#2026"
CRON_SECRET=troque-por-um-segredo-do-cron
